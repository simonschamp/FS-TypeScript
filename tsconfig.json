{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    // ADD THIS
    "baseUrl": ".",

    // OPTIONAL (if using aliases)
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
